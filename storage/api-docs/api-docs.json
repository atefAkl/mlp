        "/api/subscribe": {
            "post": {
                "tags": [
                    "Subscriptions"
                ],
                "summary": "Submit a new subscription application",
                "operationId": "057983c20fd55a9a3d6627d62df3c5c0",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "type",
                                    "email",
                                    "full_name",
                                    "country_id",
                                    "accept_conditions"
                                ],
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "example": "trainee",
                                        "enum": [
                                            "trainee",
                                            "trainer",
                                            "company"
                                        ]
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "user@example.com"
                                    },
                                    "full_name": {
                                        "type": "string",
                                        "example": "Ahmed Mohamed"
                                    },
                                    "country_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "accept_conditions": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "training_program_id": {
                                        "description": "Required for trainee",
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "trainer_opportunity_id": {
                                        "description": "Required for trainer",
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "company_package_id": {
                                        "description": "Required for company",
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "brand_name": {
                                        "description": "Required for company",
                                        "type": "string",
                                        "example": "TechCorp"
                                    },
                                    "cr_number": {
                                        "description": "Required for company",
                                        "type": "string",
                                        "example": "1010123456"
                                    },
                                    "interview_times": {
                                        "description": "Required for trainee and trainer",
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "example": [
                                            "09:00-10:00"
                                        ]
                                    },
                                    "skill_ids": {
                                        "description": "Array of selected skill IDs",
                                        "type": "array",
                                        "items": {
                                            "type": "integer"
                                        },
                                        "example": [
                                            1,
                                            2
                                        ]
                                    },
                                    "position_ids": {
                                        "description": "Array of selected position IDs",
                                        "type": "array",
                                        "items": {
                                            "type": "integer"
                                        },
                                        "example": [
                                            1,
                                            3
                                        ]
                                    },
                                    "extra_information": {
                                        "description": "Optional for company",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Subscription submitted successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Subscription submitted successfully."
                                        },
                                        "subscription_id": {
                                            "type": "string",
                                            "example": "SUB-ABC123XYZ0"
                                        },
                                        "redirect_url": {
                                            "type": "string",
                                            "example": "/subscription/SUB-ABC123XYZ0"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error"
                    }
                }
            }
        },
