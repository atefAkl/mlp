{
  "info": {
    "name": "MLP Subscriptions API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for subscriptions module (public + admin)."
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "auth_token", "value": "" },
    { "key": "subscription_id", "value": "1" },
    { "key": "subscription_public_id", "value": "" },
    { "key": "reference_id", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@quest.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns success', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('auth_token', json.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Public Subscriptions",
      "item": [
        {
          "name": "Meta",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/subscriptions/meta",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions", "meta"]
            }
          }
        },
        {
          "name": "Create Trainee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "trainee", "type": "text" },
                { "key": "email", "value": "trainee@example.com", "type": "text" },
                { "key": "full_name", "value": "Test Trainee", "type": "text" },
                { "key": "country_id", "value": "1", "type": "text" },
                { "key": "accept_conditions", "value": "1", "type": "text" },
                { "key": "stack_id", "value": "1", "type": "text" },
                { "key": "round_id", "value": "1", "type": "text" },
                { "key": "interview_times[]", "value": "09:00-10:00", "type": "text" },
                { "key": "interview_times[]", "value": "10:00-11:00", "type": "text" },
                { "key": "cv", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create trainee returns created', function () {",
                  "  pm.expect(pm.response.code).to.eql(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.subscription_id) {",
                  "  pm.collectionVariables.set('subscription_public_id', json.subscription_id);",
                  "}"
                ]
              }
            }
            ]
        },
        {
          "name": "Create Trainer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "trainer", "type": "text" },
                { "key": "email", "value": "trainer@example.com", "type": "text" },
                { "key": "full_name", "value": "Test Trainer", "type": "text" },
                { "key": "country_id", "value": "1", "type": "text" },
                { "key": "accept_conditions", "value": "1", "type": "text" },
                { "key": "position_id", "value": "1", "type": "text" },
                { "key": "interview_times[]", "value": "11:00-12:00", "type": "text" },
                { "key": "interview_times[]", "value": "13:00-14:00", "type": "text" },
                { "key": "cv", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create trainer returns created', function () {",
                  "  pm.expect(pm.response.code).to.eql(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.subscription_id) {",
                  "  pm.collectionVariables.set('subscription_public_id', json.subscription_id);",
                  "}"
                ]
              }
            }
            ]
        },
        {
          "name": "Create Company",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "company", "type": "text" },
                { "key": "email", "value": "company@example.com", "type": "text" },
                { "key": "full_name", "value": "Company Contact", "type": "text" },
                { "key": "country_id", "value": "1", "type": "text" },
                { "key": "accept_conditions", "value": "1", "type": "text" },
                { "key": "brand_name", "value": "Brand Z", "type": "text" },
                { "key": "company_field_id", "value": "1", "type": "text" },
                { "key": "package_range_id", "value": "1", "type": "text" },
                { "key": "cr_number", "value": "CR-100", "type": "text" },
                { "key": "extra_information", "value": "Need fast onboarding", "type": "text" },
                { "key": "cr", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create company returns created', function () {",
                  "  pm.expect(pm.response.code).to.eql(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.subscription_id) {",
                  "  pm.collectionVariables.set('subscription_public_id', json.subscription_id);",
                  "}"
                ]
              }
            }
            ]
        },
        {
          "name": "Public Summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/subscriptions/public/{{subscription_public_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions", "public", "{{subscription_public_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Subscribers",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/subscribers?type=trainee&status=pending&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscribers"],
              "query": [
                { "key": "type", "value": "trainee" },
                { "key": "status", "value": "pending" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        },
        {
          "name": "Grouped",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/subscribers/grouped?per_type_limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscribers", "grouped"],
              "query": [
                { "key": "per_type_limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Selection Helper",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"invert\",\n  \"type\": \"company\",\n  \"selected_ids\": [1, 2]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/subscribers/selection",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscribers", "selection"]
            }
          }
        },
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/subscribers/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscribers", "stats"]
            }
          }
        },
        {
          "name": "Trends",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/subscribers/trends?interval=daily&days=30&type=company&status=accepted",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscribers", "trends"],
              "query": [
                { "key": "interval", "value": "daily" },
                { "key": "days", "value": "30" },
                { "key": "type", "value": "company" },
                { "key": "status", "value": "accepted" }
              ]
            }
          }
        },
        {
          "name": "View Details",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/subscribers/company/{{subscription_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscribers", "company", "{{subscription_id}}"]
            }
          }
        },
        {
          "name": "Update Status Accepted",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"accepted\",\n  \"scheduled_at\": \"2026-05-25 10:30:00\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/subscribers/{{subscription_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscribers", "{{subscription_id}}", "status"]
            }
          }
        },
        {
          "name": "Update Status Rejected",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\",\n  \"reason\": \"Missing required documents\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/subscribers/{{subscription_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscribers", "{{subscription_id}}", "status"]
            }
          }
        },
        {
          "name": "Bulk Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": [1, 2, 3],\n  \"status\": \"maybe\",\n  \"reason\": \"Need additional clarification\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/subscribers/bulk-status",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscribers", "bulk-status"]
            }
          }
        },
        {
          "name": "Resend Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"maybe\",\n  \"reason\": \"Please upload clearer documents\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/subscribers/{{subscription_id}}/resend-email",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscribers", "{{subscription_id}}", "resend-email"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Reference Data",
      "item": [
        {
          "name": "Index",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reference-data",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reference-data"]
            }
          }
        },
        {
          "name": "Create Country",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Spain\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/reference-data/countries",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reference-data", "countries"]
            }
          }
        },
        {
          "name": "Update Country",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Portugal\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/reference-data/countries/{{reference_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reference-data", "countries", "{{reference_id}}"]
            }
          }
        },
        {
          "name": "Delete Country",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reference-data/countries/{{reference_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reference-data", "countries", "{{reference_id}}"]
            }
          }
        }
      ]
    }
  ]
}
